meta {
  name: Store
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/leads/store
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "lead_firstname": "John",
    "lead_lastname": "Doe",
